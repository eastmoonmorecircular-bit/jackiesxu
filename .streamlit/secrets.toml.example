# 复制内容到 Streamlit Cloud 的 Secrets 配置中
# 本地开发时不需要这个文件（用环境变量或 config.yaml）

# ===== LLM API Key（必填） =====
LLM_API_KEY = "你的智谱API Key"

# ===== Turso 云数据库（可选，配置后数据永久持久化） =====
# 不配则用本地 SQLite（部署到 Streamlit Cloud 时数据会随重启丢失）
TURSO_DATABASE_URL = "libsql://your-db.turso.io"
TURSO_AUTH_TOKEN = "你的 Turso token"
